# Firebase 프로젝트 설정값 (Firebase Console > 프로젝트 설정 > 일반 > 내 앱)
# 이 파일을 복사해서 .env.local 로 저장하고 실제 값으로 채워주세요.
# Authentication > Sign-in method 에서 "익명" 로그인을 반드시 켜야 한다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# true로 설정하면 위 값들 대신 로컬 Firestore/Auth 에뮬레이터(127.0.0.1:8080 / 127.0.0.1:9099)에 연결한다.
# 실제 Firebase 프로젝트 없이도 `firebase emulators:start --only firestore,auth` 로 전체 플로우를 테스트할 수 있다.
VITE_USE_FIREBASE_EMULATORS=false

# (선택) 카카오맵 JavaScript 키. 설정하면 모임 화면의 실시간 위치 지도 + 결과 카드 미니맵이 뜨고,
# 비워두면 두 곳 다 자동으로 안내 문구/이모지로 폴백한다 (거리/도착시간 계산 자체는 이 키와 무관하게 항상 하버사인 직선거리).
# 발급: https://developers.kakao.com > 애플리케이션 추가 > 앱 키의 "JavaScript 키" (REST API 키 아님)
# 플랫폼 설정 > Web에 사용할 도메인을 등록해야 한다 (예: http://localhost:5173, 실제 배포 도메인).
VITE_KAKAO_MAP_API_KEY=
