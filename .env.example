# Firebase 프로젝트 설정값 (Firebase Console > 프로젝트 설정 > 일반 > 내 앱)
# 이 파일을 복사해서 .env.local 로 저장하고 실제 값으로 채워주세요.
# Authentication > Sign-in method 에서 "익명" 로그인을 반드시 켜야 한다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# (선택) 방문자 수/모임 생성 수 등 핵심 지표를 Firebase Analytics(Google Analytics)로 보려면 채운다.
# Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱 하단에 "측정 ID"로 표시된다 (G-로 시작).
# 콘솔에 해당 항목이 안 보이면 프로젝트 개요 화면에서 "Google Analytics 사용 설정"부터 해야 나타난다.
# 비워두면 트래킹 코드가 조용히 아무 것도 안 하니(no-op), 안 채워도 앱은 정상 동작한다.
VITE_FIREBASE_MEASUREMENT_ID=

# true로 설정하면 위 값들 대신 로컬 Firestore/Auth 에뮬레이터(127.0.0.1:8080 / 127.0.0.1:9099)에 연결한다.
# 실제 Firebase 프로젝트 없이도 `firebase emulators:start --only firestore,auth` 로 전체 플로우를 테스트할 수 있다.
VITE_USE_FIREBASE_EMULATORS=false

# (선택) 카카오맵 JavaScript 키. 설정하면 모임 화면의 실시간 위치 지도 + 결과 카드 미니맵이 뜨고,
# 비워두면 두 곳 다 자동으로 안내 문구/이모지로 폴백한다 (거리/도착시간 계산 자체는 이 키와 무관하게 항상 하버사인 직선거리).
# 발급: https://developers.kakao.com > 애플리케이션 추가 > 앱 키의 "JavaScript 키" (REST API 키 아님)
# 플랫폼 설정 > Web에 사용할 도메인을 등록해야 한다 (예: http://localhost:5173, 실제 배포 도메인).
VITE_KAKAO_MAP_API_KEY=

# 결과 카드 지도를 서버(헤드리스 브라우저)에서 캡처하는 render 서비스가 앱에 접속할 때 쓸 주소.
# 카카오맵 JS 키가 특정 도메인에만 등록돼 있어서, 반드시 그 실제 공개 도메인(https://...)을 넣어야
# 카카오가 도메인 검증을 통과시켜 지도를 그려준다. 비워두면 도커 내부 주소로 접속해서 지도 없이
# 이모지 폴백만 캡처된다 (로컬 개발 중에는 이 정도면 충분).
PUBLIC_ORIGIN=
